{
  "programme": ["nextcloud"],
  "environment": {
    "os": "debian",
    "orchestrator": "docker",
    "arch": "x86_64",
    "cpu": "4",
    "ram": "8GB",
    "base_domain": "example.com"
  },
  "frontdoor": {
    "typ": "traefik",
    "tls": "acme",
    "proxy_headers": [
      "X-Forwarded-For",
      "X-Forwarded-Proto",
      "X-Forwarded-Host"
    ],
    "websocket_support": true,
    "http2_support": true,
    "network": "web"
  },
  "acme": {
    "email": "admin@example.com",
    "ca_server": "https://acme-v02.api.letsencrypt.org/directory",
    "staging": false
  },
  "services": {
    "nextcloud": {
      "hostname": "cloud.example.com",
      "db_type": "postgres",
      "admin_user": "admin",
      "extra_env": {
        "NEXTCLOUD_TRUSTED_DOMAINS": "cloud.example.com",
        "PHP_MEMORY_LIMIT": "512M",
        "PHP_UPLOAD_LIMIT": "10G"
      }
    },
    "keycloak": {
      "hostname": "auth.example.com",
      "db_type": "postgres"
    }
  }
}
